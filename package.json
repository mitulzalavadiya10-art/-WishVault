{
  "name": "shopify-custom-app",
  "version": "1.0.0",
  "description": "A Shopify app with Node Express backend and React Vite frontend",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "node server/index.js",
    "dev:all": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev": "shopify app dev --store s-app-store-m.myshopify.com",
    "build": "vite build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@shopify/app-bridge": "^3.7.10",
    "@shopify/app-bridge-react": "^3.7.10",
    "@shopify/polaris": "^12.0.0",
    "@shopify/shopify-api": "^11.0.0",
    "@shopify/shopify-app-session-storage-prisma": "^9.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "nodemailer": "^8.0.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "prisma": "^5.22.0",
    "vite": "^5.2.11"
  }
}
